{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wpframeblocks/code-editor-frame",
	"version": "0.1.0",
	"title": "Code Editor Frame",
	"category": "text",
	"icon": "editor-code",
	"description": "Display code inside a styled code editor frame.",
	"keywords": ["code", "editor", "frame", "syntax", "highlight"],
	"example": {},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"attributes": {
		"code": {
			"type": "string",
			"default": ""
		},
		"language": {
			"type": "string",
			"default": "javascript"
		},
		"editorTheme": {
			"type": "string",
			"default": "dark"
		},
		"fileName": {
			"type": "string",
			"default": ""
		}
	},
	"textdomain": "wpframeblocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
