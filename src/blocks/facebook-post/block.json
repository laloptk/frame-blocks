{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wpframeblocks/facebook-post",
	"version": "0.1.0",
	"title": "Facebook Post",
	"category": "media",
	"icon": "facebook",
	"description": "Display a styled Facebook post mockup.",
	"keywords": [ "facebook", "social", "post", "feed", "mockup", "fb" ],
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"pageName": {
			"type": "string",
			"default": "Page Name"
		},
		"pageSubtitle": {
			"type": "string",
			"default": "2 hrs · 🌍"
		},
		"postText": {
			"type": "string",
			"default": ""
		},
		"reactionsCount": {
			"type": "string",
			"default": "1,234"
		},
		"commentsCount": {
			"type": "string",
			"default": "56 comments"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "integer",
			"default": 0
		},
		"avatarUrl": {
			"type": "string",
			"default": ""
		},
		"avatarId": {
			"type": "integer",
			"default": 0
		},
		"isVerified": {
			"type": "boolean",
			"default": false
		},
		"isLiked": {
			"type": "boolean",
			"default": false
		},
		"maxWidth": {
			"type": "integer",
			"default": 500
		},
		"padding": {
			"type": "string",
			"default": ""
		},
		"margin": {
			"type": "string",
			"default": ""
		},
		"borderRadius": {
			"type": "integer",
			"default": 0
		},
		"borderWidth": {
			"type": "integer",
			"default": 0
		},
		"borderColor": {
			"type": "string",
			"default": ""
		}
	},
	"textdomain": "wpframeblocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
